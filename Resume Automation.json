        "jsCode": "const allItems = $input.all();\nconst miniParseNode = $('Mini Parse Extract').first();\nconst resumeEmail = miniParseNode.json.email;\n\nlet isDuplicate = false;\n\nfor (const item of allItems) {\n  const row = item.json;\n  if (row.Email === resumeEmail) {\n    isDuplicate = true;\n    break;\n  }\n}\n\nreturn {\n  is_duplicate: isDuplicate,\n  resume_email: resumeEmail\n};"
