    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet rawText = response.choices[0].message.content;\n\n// Clean markdown\nrawText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Find JSON by counting braces\nlet braceCount = 0;\nlet jsonStart = -1;\nlet jsonEnd = -1;\n\nfor (let i = 0; i < rawText.length; i++) {\n  if (rawText[i] === '{') {\n    if (braceCount === 0) jsonStart = i;\n    braceCount++;\n  }\n  if (rawText[i] === '}') {\n    braceCount--;\n    if (braceCount === 0) {\n      jsonEnd = i + 1;\n      break;\n    }\n  }\n}\n\nif (jsonStart !== -1 && jsonEnd !== -1) {\n  rawText = rawText.substring(jsonStart, jsonEnd);\n}\n\nconst parsed = JSON.parse(rawText);\n\n// Flatten skills if it's an object\nif (parsed.skills && typeof parsed.skills === 'object' && !Array.isArray(parsed.skills)) {\n  parsed.skills = Object.values(parsed.skills);\n}\n\n// Placeholder - will be replaced with actual Drive link\nparsed.resume_link = \"DRIVE_LINK_PLACEHOLDER\";\n\nreturn parsed;"
      },
