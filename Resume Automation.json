      "parameters": {
        "jsCode": "const resumeText = $('Extract from File').first().json.text;\n\nconst payload = {\n  model: \"llama-3.1-8b-instant\",\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a professional resume parser. Extract the following information from the resume and return ONLY valid JSON, no extra text:\\n\\n- full_name\\n- email\\n- phone\\n- location\\n- linkedin_url\\n- github_url\\n- portfolio_url\\n- current_role (the most recent job title from work experience)\\n- summary (2-3 sentence professional summary)\\n- skills (array of technical skills only)\\n- work_experience (array of objects: company, title, start_date, end_date, description)\\n- education (array of objects: institution, degree, field_of_study, graduation_date)\\n- certifications (array of objects: name, issuer, date)\\n- languages (array)\\n- total_years_experience (number)\\n\\nIf information not found, use null for strings, empty arrays for lists.\"\n    },\n    {\n      role: \"user\",\n      content: \"Parse this IT Developer resume:\\n\\n\" + resumeText\n    }\n  ]\n};\n\nreturn payload;"
