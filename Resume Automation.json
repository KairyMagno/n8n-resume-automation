      "parameters": {
        "jsCode": "const resumeText = $('Extract from File').first().json.text || $input.first().json.text || \"\";\n\nif (!resumeText || resumeText === \"undefined\") {\n  throw new Error(\"No resume text found. Make sure Extract from File node executed.\");\n}\n\nconst payload = {\n  model: \"llama-3.1-8b-instant\",\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a resume classifier. Determine if the resume belongs to an IT Developer.\\n\\nIT Developer = Software Developer, Web Developer, Mobile Developer, Backend/Frontend/Full Stack Developer, DevOps, Cloud Engineer, Data Engineer, QA Engineer, SDET, Game Developer.\\n\\nNOT IT Developer = IT Support, Help Desk, Network Admin, Project Manager, UI/UX Designer, Business Analyst, Teacher, Sales, ESL Tutor, Education roles.\\n\\nIf NOT an IT Developer, state the actual role found (e.g., Teacher, ESL Tutor, Sales Associate). If no clear role, state No IT experience found.\\n\\nRespond with ONLY valid JSON:\\n{\\\"is_it_developer\\\": true/false, \\\"reason\\\": \\\"Actual role found or reason for rejection\\\"}\"\n    },\n    {\n      role: \"user\",\n      content: \"Classify this resume:\\n\\n\" + resumeText\n    }\n  ]\n};\n\nreturn payload;"
